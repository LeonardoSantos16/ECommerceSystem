{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Debug",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "checkout-cluster",
        "RateLimiterPolicy": "customPolicy",
        "Match": {
          "Path": "/api/checkout/{**remainder}"
        }
      },
      "payment-webhook-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments/webhooks/{**remainder}"
        }
      }
    },
    "Clusters": {
      "checkout-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "instancia-1": {
            "Address": "http://localhost:5056"
          },
          "instancia-2": {
            "Address": "http://localhost:5057"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-api-1": {
            "Address": "http://localhost:5095"
          }
        }
      }
    }
  }
}